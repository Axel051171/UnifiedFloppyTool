# hermes-agent PoC environment template
# NIE diese Datei mit echten Keys committen — sie ist das Template.
# Echte Keys gehören in .env (gitignored).

# === Modell-Endpoint ===
# Wähle EINEN — die anderen leer/auskommentiert lassen.

# Option 1: OpenRouter (empfohlen für fairen Vergleich gegen Claude Code)
# Erlaubt anthropic/claude-3.5-sonnet als Modell.
OPENROUTER_API_KEY=

# Option 2: Nous Portal (Native für hermes-agent, könnte optimiert sein)
NOUS_PORTAL_API_KEY=

# Option 3: NovitaAI
NOVITA_API_KEY=

# Option 4: Lokales Endpoint (Ollama/llama.cpp/vllm)
# Disqualifiziert vom GO-Vergleich (zu unterschiedliche Hardware-Performance)
# aber gut für Sanity-Check ob hermes überhaupt läuft.
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=

# === Benchmark-Konfiguration ===

# Pfad zu disposable Test-Branch für Task A (wird im Skript erzeugt)
HERMES_BENCH_TEST_BRANCH=test/hermes-eval-disposable

# Output-Verzeichnis für gemessene Ergebnisse
HERMES_BENCH_RESULTS_DIR=./results

# Wall-Clock-Limit pro Task — wenn überschritten = automatischer NO-GO
# auf diesem Task (KO-Kriterium aus Goal-File: > 30 % schlechter Wall-Clock)
HERMES_BENCH_TIMEOUT_SECONDS=300
