/**
 * @file uft_crc16_@@variant@@.c
 * @brief CRC-16/@@VARIANT@@ implementation.
 *
 * Parameters:
 *   Polynomial:       0x@@poly@@
 *   Initial value:    0x@@init@@
 *   Input reflected:  @@ref_in@@
 *   Output reflected: @@ref_out@@
 *   XOR out:          0x@@xor_out@@
 *
 * Verified against: reveng -c -m CRC-16/@@VARIANT@@
 * Reference check:  crc_reference.py --family @@variant@@ --input <hex>
 *
 * Test vectors (add more as format spec provides):
 *   "123456789" init=0x@@init@@ → 0x@@check_value@@
 */
#include "uft/crc/uft_crc_unified.h"
#include <stdint.h>
#include <stddef.h>

uint16_t uft_crc16_@@variant@@(const uint8_t *data, size_t len, uint16_t init)
{
    uint16_t crc = init;
    for (size_t i = 0; i < len; i++) {
        crc ^= (uint16_t)data[i] << 8;
        for (int b = 0; b < 8; b++) {
            crc = (crc & 0x8000) ? (uint16_t)((crc << 1) ^ 0x@@poly@@)
                                  : (uint16_t)(crc << 1);
        }
    }
    /* If XorOut != 0: crc ^= 0x@@xor_out@@; */
    return crc;
}
