/**
 * @file bench_@@function@@.c
 * @brief Micro-benchmark for @@function@@.
 *
 * Reference workload: @@workload_size@@ @@unit@@ per iteration.
 * Reports min/median/max over 11 measurement iterations, after 3 warmups.
 */

#include <stdio.h>
#include <stdint.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

/* The function under test — adjust include path as needed */
/* #include "uft/flux/uft_flux_decoder.h" */

#define WORKLOAD_SIZE       @@workload_size@@
#define WARMUP_ITERATIONS   3
#define MEASURE_ITERATIONS  11

static uint64_t now_ns(void) {
    struct timespec ts;
    clock_gettime(CLOCK_MONOTONIC, &ts);
    return (uint64_t)ts.tv_sec * 1000000000ULL + (uint64_t)ts.tv_nsec;
}

static int cmp_u64(const void *a, const void *b) {
    uint64_t x = *(const uint64_t *)a, y = *(const uint64_t *)b;
    return (x > y) - (x < y);
}

static void build_workload(uint8_t *buf, size_t size) {
    /* Deterministic LCG — fixtures must match run-to-run */
    uint32_t seed = 0x4E554654u;
    for (size_t i = 0; i < size; i++) {
        seed = seed * 1103515245u + 12345u;
        buf[i] = (uint8_t)(seed >> 16);
    }
}

int main(void) {
    /* Allocate workload — using size in bytes */
    size_t workload_bytes = (WORKLOAD_SIZE + 7) / 8;
    uint8_t *workload = malloc(workload_bytes);
    if (!workload) {
        fprintf(stderr, "allocation failed\n");
        return 1;
    }
    build_workload(workload, workload_bytes);

    /* Warmup — run the function but discard timings */
    for (int i = 0; i < WARMUP_ITERATIONS; i++) {
        /* TODO: call the function under test */
        /* volatile int r = @@function@@(workload, WORKLOAD_SIZE, 0x4489); */
        /* (void)r; */
    }

    /* Measure */
    uint64_t samples[MEASURE_ITERATIONS];
    for (int i = 0; i < MEASURE_ITERATIONS; i++) {
        uint64_t t0 = now_ns();

        /* TODO: call the function under test */
        volatile int result = 0;
        /* result = @@function@@(workload, WORKLOAD_SIZE, 0x4489); */

        uint64_t t1 = now_ns();
        (void)result;
        samples[i] = t1 - t0;
    }

    qsort(samples, MEASURE_ITERATIONS, sizeof(samples[0]), cmp_u64);
    uint64_t min_ns = samples[0];
    uint64_t med_ns = samples[MEASURE_ITERATIONS / 2];
    uint64_t max_ns = samples[MEASURE_ITERATIONS - 1];

    double thruput = (double)WORKLOAD_SIZE / (med_ns / 1e9);

    printf("@@function@@ @ %d @@unit@@:\n", WORKLOAD_SIZE);
    printf("  min:      %7.2f ms\n", min_ns / 1e6);
    printf("  median:   %7.2f ms  (%.1f M@@unit@@/sec)\n",
           med_ns / 1e6, thruput / 1e6);
    printf("  max:      %7.2f ms\n", max_ns / 1e6);

    free(workload);
    return 0;
}
